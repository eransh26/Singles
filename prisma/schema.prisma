generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum VerificationStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum ThemePreference {
  LIGHT
  DARK
}

enum ProfileVisibility {
  PUBLIC
  MEMBERS_ONLY
  PRIVATE
}

enum ChatRequestPolicy {
  EVERYONE
  VERIFIED_ONLY
  NOBODY
}

enum PhotoRequestPolicy {
  VERIFIED_ONLY
  NOBODY
}

enum ActivityVisibility {
  SHOW
  HIDE
}

enum MediaType {
  PROFILE
  GALLERY
}

enum MediaVisibilityLevel {
  PUBLIC
  APPROVED
  PRIVATE
}

enum GroupType {
  OPEN
  CLOSED
  INVITE_ONLY
}

enum GroupStatus {
  ACTIVE
  ARCHIVED
  DISABLED
}

enum MembershipStatus {
  ACTIVE
  LEFT
  BANNED
}

enum GroupRole {
  MEMBER
  MANAGER
  OWNER
}

enum GroupJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum PostContextType {
  GLOBAL_FEED
  GROUP
}

enum PostVisibilityStatus {
  VISIBLE
  HIDDEN
  DELETED
}

enum ReactionType {
  LOVE
  SUPPORT
  THUMBS_UP
  CELEBRATE
}

enum PostSensitivityStatus {
  NORMAL
  SELF_MARKED_SENSITIVE
  SYSTEM_SENSITIVE
}

enum MediaStorageProvider {
  LEGACY_INLINE
  R2
}

enum MediaModerationStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ModerationStatus {
  CLEAN
  UNDER_REVIEW
  REMOVED
}

enum ChatRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
  EXPIRED
}

enum ChatRequestOriginType {
  STANDARD
  SINGLE_OF_WEEK
}

enum ConsentStatus {
  PENDING
  APPROVED
  DECLINED
  REVOKED
  CANCELED
}

enum ConversationKind {
  MEMBER_CHAT
  BUDDY_SUPPORT
}

enum BuddySupportMode {
  CHAT_ONLY
  VIDEO_OK
  EITHER
}

enum BuddyAvailabilityLevel {
  LIGHT
  STANDARD
  HIGH
}

enum BuddyApplicationStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum BuddyApplicationDomainStatus {
  PENDING_RECOMMENDATIONS
  REPLACEMENT_NEEDED
  PENDING_ADMIN_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

enum BuddyRecommendationStatus {
  PENDING
  APPROVED
  DECLINED
}

enum SingleOfWeekApplicationStatus {
  SUBMITTED
  SHORTLISTED
  SELECTED
  REJECTED
  WITHDRAWN
}

enum SingleOfWeekFeatureStatus {
  UPCOMING
  AWAITING_RESPONSE
  ACTIVE
  DECLINED
  HIDDEN
  COMPLETED
  CANCELLED
}

enum BuddyRequestStatus {
  PENDING
  ASSIGNED
  AWAITING_SEEKER_DECISION
  CANCELLED
  CLOSED
}

enum BuddyRequestAssignmentStatus {
  PENDING
  ACCEPTED
  DECLINED
  NOT_RELEVANT
}

enum ConversationStatus {
  ACTIVE
  CLOSED
  BLOCKED
}

enum MessageAttachmentKind {
  IMAGE
  FILE
}

enum PhotoAccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
  EXPIRED
}

enum NotificationType {
  CHAT_REQUEST_INCOMING
  CHAT_REQUEST_ACCEPTED
  CHAT_MESSAGE_RECEIVED
  VIDEO_REQUEST_INCOMING
  VIDEO_REQUEST_APPROVED
  PHOTO_ACCESS_REQUEST_INCOMING
  PHOTO_ACCESS_APPROVED
  GROUP_JOIN_APPROVED
  COMMENT_RECEIVED
  REPORT_UPDATE
  SYSTEM
  BUDDY_REQUEST_SUBMITTED
  BUDDY_REQUEST_INCOMING
  BUDDY_REQUEST_ASSIGNED
  BUDDY_REQUEST_DECISION_NEEDED
  BUDDY_REQUEST_NO_MATCH
  BUDDY_REQUEST_CANCELLED
  BUDDY_REQUEST_NO_LONGER_RELEVANT
  BUDDY_VIDEO_REQUEST_INCOMING
  BUDDY_VIDEO_REQUEST_APPROVED
}

enum NotificationEmailStatus {
  PENDING
  SKIPPED
  SENT
  FAILED
}

enum ActivityContextType {
  APP
  CHAT_CONVERSATION
  BUDDY_CONVERSATION
}

enum FeatureFlagRolloutType {
  GLOBAL
  ADMIN_ONLY
  USER_LIST
  PERCENTAGE
}

enum ReportTargetType {
  USER
  POST
  COMMENT
  MESSAGE
  MESSAGE_ATTACHMENT
  GROUP
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
}

enum EventPromotionStatus {
  DRAFT
  ACTIVE
  INACTIVE
  EXPIRED
}

enum PlacementType {
  HOME_FEED_CARD
  GROUPS_LIST_BANNER
  GROUP_DETAIL_BANNER
}

model User {
  id                   String @id @default(cuid())
  email                String @unique
  emailVerified        DateTime?
  phone                String? @unique
  passwordHash         String?
  displayName          String
  bio                  String?
  region               String?
  ageVerified          Boolean @default(false)
  phoneVerifiedAt      DateTime?
  verificationStatus   VerificationStatus @default(NONE)
  verifiedBadgeVisible Boolean @default(true)
  profileVisibility    ProfileVisibility @default(MEMBERS_ONLY)
  chatRequestPolicy    ChatRequestPolicy @default(EVERYONE)
  photoRequestPolicy   PhotoRequestPolicy @default(VERIFIED_ONLY)
  activityVisibility   ActivityVisibility @default(SHOW)
  accountStatus        AccountStatus @default(ACTIVE)
  role                 UserRole @default(USER)
  isTestUser           Boolean @default(false)
  image                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  settings               UserSettings?
  profileImageAssets     UserProfileImageAsset[]
  media                  UserProfileMedia[]
  buddyProfile           BuddyProfile?
  buddyApplications      BuddyApplication[] @relation("BuddyApplicationApplicant")
  buddyApplicationRecommendations BuddyApplicationRecommendation[] @relation("BuddyRecommendationRecommender")
  buddyReapplicationOverrides     BuddyReapplicationOverride[] @relation("BuddyReapplicationSubject")
  buddyReapplicationOverridesGranted BuddyReapplicationOverride[] @relation("BuddyReapplicationAdmin")
  buddyApplicationsApproved       BuddyApplicationDomain[] @relation("BuddyApplicationDomainApprovedBy")
  buddyApplicationsRejected       BuddyApplicationDomain[] @relation("BuddyApplicationDomainRejectedBy")
  singleOfWeekApplications        SingleOfWeekApplication[] @relation("SingleOfWeekApplicationApplicant")
  singleOfWeekFeatures            SingleOfWeekFeature[] @relation("SingleOfWeekFeatureUser")
  singleOfWeekSelections          SingleOfWeekFeature[] @relation("SingleOfWeekSelectedByAdmin")
  singleOfWeekResponses           SingleOfWeekFeature[] @relation("SingleOfWeekRespondedByUser")
  singleOfWeekViews               SingleOfWeekView[]
  buddyRequestsSought    BuddyRequest[] @relation("BuddyRequestSeeker")
  buddyRequestsAssigned  BuddyRequest[] @relation("BuddyRequestAssignedBuddy")
  buddyAssignments       BuddyRequestAssignment[] @relation("BuddyRequestAssignmentBuddy")
  buddyVideoConsentsRequested BuddyVideoConsent[] @relation("BuddyVideoConsentRequester")
  buddyVideoConsentsReceived  BuddyVideoConsent[] @relation("BuddyVideoConsentTarget")
  buddyVideoConsentsApproved  BuddyVideoConsent[] @relation("BuddyVideoConsentApprover")
  interests              UserInterest[]
  verificationRequests   VerificationRequest[] @relation("VerificationRequestSubject")
  verificationReviewed   VerificationRequest[] @relation("VerificationRequestReviewer")

  groupsCreated          Group[] @relation("GroupCreatedBy")
  memberships            GroupMembership[]
  joinRequestsFiled      GroupJoinRequest[] @relation("GroupJoinRequestApplicant")
  joinRequestsReviewed   GroupJoinRequest[] @relation("GroupJoinRequestReviewer")

  posts                  Post[]
  comments               Comment[]
  postReactions          PostReaction[]

  chatRequestsSent       ChatRequest[] @relation("ChatRequestFromUser")
  chatRequestsReceived   ChatRequest[] @relation("ChatRequestToUser")
  conversationsOne       Conversation[] @relation("ConversationUserOne")
  conversationsTwo       Conversation[] @relation("ConversationUserTwo")
  messages               Message[]
  startedVideoCalls      VideoCallRecord[] @relation("VideoCallStartedBy")
  videoConsentsRequested VideoConsent[] @relation("VideoConsentRequester")
  videoConsentsReceived  VideoConsent[] @relation("VideoConsentTarget")
  videoConsentsApproved  VideoConsent[] @relation("VideoConsentApprover")

  blocksInitiated        UserBlock[] @relation("UserBlockBlocker")
  blocksReceived         UserBlock[] @relation("UserBlockBlocked")

  photoRequestsSent      PhotoAccessRequest[] @relation("PhotoAccessRequester")
  photoRequestsOwned     PhotoAccessRequest[] @relation("PhotoAccessOwner")
  photoGrantsOwned       PhotoAccessGrant[] @relation("PhotoGrantOwner")
  photoGrantsReceived    PhotoAccessGrant[] @relation("PhotoGrantGrantee")

  notifications          Notification[]
  webPushSubscriptions  WebPushSubscription[]
  emailFallbacks        NotificationEmailFallback[]
  activityState         UserActivityState?
  reportsFiled           Report[] @relation("ReportFiledBy")
  reportsResolved        Report[] @relation("ReportResolvedBy")
  reportsAgainstUser     Report[] @relation("ReportTargetUser")
  audits                 AuditLog[]

  eventPromotionsCreated EventPromotion[] @relation("EventPromotionCreatedBy")

  accounts               Account[]
  sessions               Session[]
}

model UserSettings {
  userId                    String @id
  themePreference           ThemePreference @default(LIGHT)
  webPushEnabled            Boolean @default(false)
  emailActivityEnabled      Boolean @default(true)
  silentModeEnabled         Boolean @default(false)
  hideLockScreenTextEnabled Boolean @default(false)
  pushPromptDismissedAt     DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserActivityState {
  userId           String @id
  lastActiveAt     DateTime @default(now())
  contextType      ActivityContextType @default(APP)
  contextId        String?
  isVisible        Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastActiveAt])
  @@index([contextType, contextId])
}

model FeatureFlag {
  id          String                 @id @default(cuid())
  key         String                 @unique
  enabled     Boolean                @default(false)
  description String?
  rolloutType FeatureFlagRolloutType @default(GLOBAL)
  rolloutValue Json?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([enabled, rolloutType])
}

model Interest {
  id        String @id @default(cuid())
  name      String
  slug      String @unique
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())

  users     UserInterest[]
}

model UserInterest {
  id         String @id @default(cuid())
  userId     String
  interestId String
  createdAt  DateTime @default(now())

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)
  interest   Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@unique([userId, interestId])
  @@index([interestId])
}

model UserProfileMedia {
  id              String @id @default(cuid())
  userId          String
  mediaType       MediaType
  storageKey      String
  visibilityLevel MediaVisibilityLevel @default(PRIVATE)
  sortOrder       Int @default(0)
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mediaType, isActive])
}

model UserProfileImageAsset {
  id               String                @id @default(cuid())
  userId           String
  objectKey        String
  storageProvider  MediaStorageProvider  @default(R2)
  mimeType         String
  moderationStatus MediaModerationStatus @default(PENDING_REVIEW)
  uploadedAt       DateTime              @default(now())
  reviewedAt       DateTime?
  moderationNote   String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, moderationStatus, uploadedAt])
}

model VerificationRequest {
  id               String @id @default(cuid())
  userId           String
  status           VerificationStatus @default(PENDING)
  note             String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User @relation("VerificationRequestSubject", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy       User? @relation("VerificationRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
}

model UserBlock {
  id            String @id @default(cuid())
  blockerUserId String
  blockedUserId String
  reason        String?
  createdAt     DateTime @default(now())

  blocker       User @relation("UserBlockBlocker", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blocked       User @relation("UserBlockBlocked", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerUserId, blockedUserId])
  @@index([blockedUserId])
}

model Group {
  id                  String @id @default(cuid())
  name                String
  slug                String @unique
  description         String?
  groupType           GroupType
  isSmallPrivateGroup Boolean @default(false)
  status              GroupStatus @default(ACTIVE)
  createdByUserId     String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  createdBy           User @relation("GroupCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  memberships         GroupMembership[]
  joinQuestions       GroupJoinQuestion[]
  joinRequests        GroupJoinRequest[]
  posts               Post[]
  reports             Report[] @relation("ReportTargetGroup")
  eventPlacements     EventPromotionPlacement[]

  @@index([groupType, status])
}

model GroupMembership {
  id         String @id @default(cuid())
  groupId    String
  userId     String
  role       GroupRole @default(MEMBER)
  status     MembershipStatus @default(ACTIVE)
  joinedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  group      Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId, status])
}

model GroupJoinQuestion {
  id           String @id @default(cuid())
  groupId      String
  questionText String
  sortOrder    Int @default(0)
  isRequired   Boolean @default(true)
  createdAt    DateTime @default(now())

  group        Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  answers      GroupJoinAnswer[]

  @@index([groupId, sortOrder])
}

model GroupJoinRequest {
  id               String @id @default(cuid())
  groupId          String
  applicantUserId  String
  pairKey          String
  pendingKey       String? @unique
  status           GroupJoinRequestStatus @default(PENDING)
  requestMessage   String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  group            Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  applicant        User @relation("GroupJoinRequestApplicant", fields: [applicantUserId], references: [id], onDelete: Cascade)
  reviewedBy       User? @relation("GroupJoinRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  answers          GroupJoinAnswer[]

  @@index([groupId, status, createdAt])
  @@index([applicantUserId, status])
  @@index([pairKey, createdAt])
}

model GroupJoinAnswer {
  id            String @id @default(cuid())
  joinRequestId String
  questionId    String
  answerText    String
  createdAt     DateTime @default(now())

  joinRequest   GroupJoinRequest @relation(fields: [joinRequestId], references: [id], onDelete: Cascade)
  question      GroupJoinQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([joinRequestId, questionId])
}

model Post {
  id               String @id @default(cuid())
  authorUserId     String
  contextType      PostContextType
  groupId          String?
  contentText      String
  isAnonymous      Boolean @default(false)
  sensitivityStatus PostSensitivityStatus @default(NORMAL)
  visibilityStatus PostVisibilityStatus @default(VISIBLE)
  moderationStatus ModerationStatus @default(CLEAN)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  author           User @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  group            Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  media            PostMedia[]
  comments         Comment[]
  reactions        PostReaction[]
  reports          Report[] @relation("ReportTargetPost")

  @@index([contextType, createdAt])
  @@index([groupId, createdAt])
}

model PostMedia {
  id         String @id @default(cuid())
  postId     String
  storageKey String
  sortOrder  Int @default(0)
  createdAt  DateTime @default(now())

  post       Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model PostReaction {
  id           String       @id @default(cuid())
  postId       String
  userId       String
  reactionType ReactionType @default(LOVE)
  createdAt    DateTime     @default(now())

  post       Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

model Comment {
  id               String @id @default(cuid())
  postId           String
  authorUserId     String
  contentText      String
  moderationStatus ModerationStatus @default(CLEAN)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  post             Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author           User @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  reports          Report[] @relation("ReportTargetComment")

  @@index([postId, createdAt])
}

model ChatRequest {
  id           String @id @default(cuid())
  fromUserId   String
  toUserId     String
  pairKey      String
  pendingKey   String? @unique
  originType   ChatRequestOriginType @default(STANDARD)
  singleOfWeekFeatureId String?
  status       ChatRequestStatus @default(PENDING)
  createdAt    DateTime @default(now())
  respondedAt  DateTime?

  fromUser     User @relation("ChatRequestFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser       User @relation("ChatRequestToUser", fields: [toUserId], references: [id], onDelete: Cascade)
  singleOfWeekFeature SingleOfWeekFeature? @relation(fields: [singleOfWeekFeatureId], references: [id], onDelete: SetNull)
  conversation Conversation?

  @@index([toUserId, status, createdAt])
  @@index([pairKey, createdAt])
  @@index([singleOfWeekFeatureId, createdAt])
}

model Conversation {
  id                        String @id @default(cuid())
  userOneId                 String
  userTwoId                 String
  pairKey                   String @unique
  kind                      ConversationKind @default(MEMBER_CHAT)
  status                    ConversationStatus @default(ACTIVE)
  createdFromChatRequestId  String? @unique
  buddyRequestId            String? @unique
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  userOne                   User @relation("ConversationUserOne", fields: [userOneId], references: [id], onDelete: Cascade)
  userTwo                   User @relation("ConversationUserTwo", fields: [userTwoId], references: [id], onDelete: Cascade)
  createdFromChatRequest    ChatRequest? @relation(fields: [createdFromChatRequestId], references: [id], onDelete: Restrict)
  buddyRequest              BuddyRequest? @relation("BuddyRequestConversation", fields: [buddyRequestId], references: [id], onDelete: SetNull)
  messages                  Message[]
  videoCallRecords          VideoCallRecord[]
  buddyVideoConsent         BuddyVideoConsent?

  @@index([kind, status, updatedAt])
}

model Message {
  id             String @id @default(cuid())
  conversationId String
  senderUserId   String
  body           String
  createdAt      DateTime @default(now())
  deletedAt      DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  attachments    MessageAttachment[]
  reports        Report[] @relation("ReportTargetMessage")

  @@index([conversationId, createdAt])
}

model MessageAttachment {
  id         String @id @default(cuid())
  messageId  String
  kind       MessageAttachmentKind
  fileName   String
  mimeType   String
  byteSize   Int
  storageKey String
  createdAt  DateTime @default(now())
  deletedAt  DateTime?

  message    Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reports    Report[] @relation("ReportTargetMessageAttachment")

  @@index([messageId, createdAt])
}

model VideoCallRecord {
  id                    String @id @default(cuid())
  conversationId        String
  roomName              String
  startedByUserId       String
  startedAt             DateTime @default(now())
  endedAt               DateTime?
  lastJoinedAt          DateTime?
  activeConversationKey String? @unique

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  startedBy       User @relation("VideoCallStartedBy", fields: [startedByUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, startedAt])
  @@index([roomName, endedAt])
}

model VideoConsent {
  id               String @id @default(cuid())
  pairKey          String @unique
  requesterUserId  String
  targetUserId     String
  approvedByUserId String?
  status           ConsentStatus @default(PENDING)
  createdAt        DateTime @default(now())
  respondedAt      DateTime?
  updatedAt        DateTime @updatedAt

  requester        User @relation("VideoConsentRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  target           User @relation("VideoConsentTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  approvedBy       User? @relation("VideoConsentApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([targetUserId, status, createdAt])
  @@index([requesterUserId, status, createdAt])
}

model BuddyDomainRecord {
  id          String @id @default(cuid())
  slug        String @unique
  name        String @unique
  description String?
  isActive    Boolean @default(true)
  sortOrder   Int @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  buddyProfiles           BuddyProfileDomain[]
  buddyRequests           BuddyRequest[]
  buddyApplicationDomains BuddyApplicationDomain[]
  reapplicationOverrides  BuddyReapplicationOverride[]

  @@index([isActive, sortOrder])
}

model BuddyProfile {
  userId            String @id
  isAvailable       Boolean @default(false)
  intro             String?
  availabilityLevel BuddyAvailabilityLevel?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)
  domains           BuddyProfileDomain[]
}

model BuddyProfileDomain {
  id                String @id @default(cuid())
  userId            String
  domainId          String
  createdAt         DateTime @default(now())
  approvedApplicationDomainId String? @unique

  profile           BuddyProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  domain            BuddyDomainRecord @relation(fields: [domainId], references: [id], onDelete: Restrict)
  approvedApplicationDomain BuddyApplicationDomain? @relation(fields: [approvedApplicationDomainId], references: [id], onDelete: SetNull)

  @@unique([userId, domainId])
  @@index([domainId])
}

model BuddyApplication {
  id                String @id @default(cuid())
  applicantUserId   String
  intro             String
  availabilityLevel BuddyAvailabilityLevel
  status            BuddyApplicationStatus @default(ACTIVE)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  cancelledAt       DateTime?
  completedAt       DateTime?

  applicant         User @relation("BuddyApplicationApplicant", fields: [applicantUserId], references: [id], onDelete: Cascade)
  domains           BuddyApplicationDomain[]

  @@index([applicantUserId, status, createdAt])
}

model BuddyApplicationDomain {
  id                String @id @default(cuid())
  applicationId     String
  domainId          String
  status            BuddyApplicationDomainStatus @default(PENDING_RECOMMENDATIONS)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  adminReviewedAt   DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  approvedByAdminId String?
  rejectedByAdminId String?

  application       BuddyApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  domain            BuddyDomainRecord @relation(fields: [domainId], references: [id], onDelete: Restrict)
  recommendations   BuddyApplicationRecommendation[]
  approvedByAdmin   User? @relation("BuddyApplicationDomainApprovedBy", fields: [approvedByAdminId], references: [id], onDelete: SetNull)
  rejectedByAdmin   User? @relation("BuddyApplicationDomainRejectedBy", fields: [rejectedByAdminId], references: [id], onDelete: SetNull)
  approvedBuddyProfileDomain BuddyProfileDomain?

  @@index([status, createdAt])
  @@unique([applicationId, domainId])
}

model BuddyApplicationRecommendation {
  id                String @id @default(cuid())
  applicationDomainId String
  recommenderUserId String
  status            BuddyRecommendationStatus @default(PENDING)
  note              String?
  createdAt         DateTime @default(now())
  submittedAt       DateTime?
  replacedAt        DateTime?

  applicationDomain BuddyApplicationDomain @relation(fields: [applicationDomainId], references: [id], onDelete: Cascade)
  recommender       User @relation("BuddyRecommendationRecommender", fields: [recommenderUserId], references: [id], onDelete: Cascade)

  @@index([recommenderUserId, status, createdAt])
  @@index([applicationDomainId, replacedAt])
}

model BuddyReapplicationOverride {
  id                String @id @default(cuid())
  userId            String
  domainId          String
  grantedByAdminId  String
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User @relation("BuddyReapplicationSubject", fields: [userId], references: [id], onDelete: Cascade)
  domain            BuddyDomainRecord @relation(fields: [domainId], references: [id], onDelete: Cascade)
  grantedByAdmin    User @relation("BuddyReapplicationAdmin", fields: [grantedByAdminId], references: [id], onDelete: Cascade)

  @@unique([userId, domainId])
}

model BuddyRequest {
  id                String @id @default(cuid())
  seekerId          String
  domainId          String
  message           String?
  preferredMode     BuddySupportMode
  status            BuddyRequestStatus @default(PENDING)
  assignedBuddyId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  extensionPromptAt DateTime?
  expiresAt         DateTime
  extendedAt        DateTime?
  closedAt          DateTime?

  seeker            User @relation("BuddyRequestSeeker", fields: [seekerId], references: [id], onDelete: Cascade)
  assignedBuddy     User? @relation("BuddyRequestAssignedBuddy", fields: [assignedBuddyId], references: [id], onDelete: SetNull)
  domain            BuddyDomainRecord @relation(fields: [domainId], references: [id], onDelete: Restrict)
  assignments       BuddyRequestAssignment[]
  conversation      Conversation? @relation("BuddyRequestConversation")

  @@index([seekerId, status, createdAt])
  @@index([status, domainId, createdAt])
}

model BuddyRequestAssignment {
  id                String @id @default(cuid())
  buddyRequestId    String
  buddyId           String
  status            BuddyRequestAssignmentStatus @default(PENDING)
  createdAt         DateTime @default(now())
  respondedAt       DateTime?

  buddyRequest      BuddyRequest @relation(fields: [buddyRequestId], references: [id], onDelete: Cascade)
  buddy             User @relation("BuddyRequestAssignmentBuddy", fields: [buddyId], references: [id], onDelete: Cascade)

  @@unique([buddyRequestId, buddyId])
  @@index([buddyId, status, createdAt])
}

model BuddyVideoConsent {
  id                String @id @default(cuid())
  conversationId    String @unique
  requesterUserId   String
  targetUserId      String
  approvedByUserId  String?
  status            ConsentStatus @default(PENDING)
  createdAt         DateTime @default(now())
  respondedAt       DateTime?
  updatedAt         DateTime @updatedAt

  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  requester         User @relation("BuddyVideoConsentRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  target            User @relation("BuddyVideoConsentTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  approvedBy        User? @relation("BuddyVideoConsentApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([targetUserId, status, createdAt])
  @@index([requesterUserId, status, createdAt])
}

model SingleOfWeekApplication {
  id                 String @id @default(cuid())
  applicantUserId    String
  bio                String
  interests          String?
  hobbies            String?
  relationshipIntent String?
  preferredLocation  String?
  consentedAt        DateTime
  status             SingleOfWeekApplicationStatus @default(SUBMITTED)
  submittedAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  shortlistedAt      DateTime?
  selectedAt         DateTime?
  rejectedAt         DateTime?
  withdrawnAt        DateTime?
  adminNotes         String?
  shortlistScore     Int?

  applicant          User @relation("SingleOfWeekApplicationApplicant", fields: [applicantUserId], references: [id], onDelete: Cascade)
  photos             SingleOfWeekApplicationPhoto[]
  features           SingleOfWeekFeature[]

  @@index([applicantUserId, status, submittedAt])
  @@index([status, submittedAt])
}

model SingleOfWeekApplicationPhoto {
  id               String                @id @default(cuid())
  applicationId    String
  storageKey       String
  storageProvider  MediaStorageProvider  @default(LEGACY_INLINE)
  mimeType         String?
  moderationStatus MediaModerationStatus @default(APPROVED)
  uploadedAt       DateTime              @default(now())
  reviewedAt       DateTime?
  moderationNote   String?
  sortOrder        Int                   @default(0)
  createdAt        DateTime              @default(now())

  application   SingleOfWeekApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, sortOrder])
}

model SingleOfWeekFeature {
  id                String @id @default(cuid())
  applicationId     String
  featuredUserId    String
  weekOf            DateTime @unique
  publishAt         DateTime
  notifyAt          DateTime
  status            SingleOfWeekFeatureStatus @default(UPCOMING)
  selectedByAdminId String
  respondedByUserId String?
  selectedAt        DateTime @default(now())
  notifiedAt        DateTime?
  acceptedAt        DateTime?
  declinedAt        DateTime?
  hiddenAt          DateTime?
  hiddenReason      String?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  application       SingleOfWeekApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  featuredUser      User @relation("SingleOfWeekFeatureUser", fields: [featuredUserId], references: [id], onDelete: Cascade)
  selectedByAdmin   User @relation("SingleOfWeekSelectedByAdmin", fields: [selectedByAdminId], references: [id], onDelete: Restrict)
  respondedByUser   User? @relation("SingleOfWeekRespondedByUser", fields: [respondedByUserId], references: [id], onDelete: SetNull)
  requestLimitOverride SingleOfWeekFeatureLimitOverride?
  views             SingleOfWeekView[]
  chatRequests      ChatRequest[]

  @@index([status, publishAt])
  @@index([featuredUserId, status, weekOf])
}

model SingleOfWeekFeatureLimitOverride {
  featureId    String @id
  dailyCap     Int?
  weeklyCap    Int?
  monthlyCap   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  feature      SingleOfWeekFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)
}

model SingleOfWeekConfig {
  id                String @id
  targetDailyCap    Int @default(10)
  targetWeeklyCap   Int @default(20)
  targetMonthlyCap  Int @default(50)
  requesterDailyCap Int @default(3)
  requesterWeeklyCap Int @default(6)
  requesterMonthlyCap Int @default(12)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SingleOfWeekView {
  id          String @id @default(cuid())
  featureId   String
  viewerUserId String
  viewedAt    DateTime @default(now())

  feature     SingleOfWeekFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  viewer      User @relation(fields: [viewerUserId], references: [id], onDelete: Cascade)

  @@unique([featureId, viewerUserId])
  @@index([featureId, viewedAt])
}

model PhotoAccessRequest {
  id              String @id @default(cuid())
  requesterUserId String
  ownerUserId     String
  pairKey         String
  pendingKey      String? @unique
  status          PhotoAccessRequestStatus @default(PENDING)
  createdAt       DateTime @default(now())
  respondedAt     DateTime?

  requester       User @relation("PhotoAccessRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  owner           User @relation("PhotoAccessOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  grant           PhotoAccessGrant?

  @@index([ownerUserId, status, createdAt])
  @@index([requesterUserId, status, createdAt])
  @@index([pairKey, createdAt])
}

model PhotoAccessGrant {
  id            String @id @default(cuid())
  requestId     String @unique
  ownerUserId   String
  granteeUserId String
  grantedAt     DateTime @default(now())
  revokedAt     DateTime?

  request       PhotoAccessRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  owner         User @relation("PhotoGrantOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  grantee       User @relation("PhotoGrantGrantee", fields: [granteeUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, granteeUserId])
}

model EventPromotion {
  id              String @id @default(cuid())
  title           String
  description     String?
  imageUrl        String?
  externalLink    String
  couponCode      String?
  status          EventPromotionStatus @default(DRAFT)
  startsAt        DateTime?
  endsAt          DateTime?
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy       User @relation("EventPromotionCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  placements      EventPromotionPlacement[]
}

model EventPromotionPlacement {
  id               String @id @default(cuid())
  eventPromotionId String
  placementType    PlacementType
  groupId          String?
  priority         Int @default(0)
  isActive         Boolean @default(true)
  createdAt        DateTime @default(now())

  eventPromotion   EventPromotion @relation(fields: [eventPromotionId], references: [id], onDelete: Cascade)
  group            Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([placementType, isActive, priority])
  @@index([groupId, isActive])
}

model Notification {
  id               String @id @default(cuid())
  userId           String
  type             NotificationType
  payloadJson      Json
  isRead           Boolean @default(false)
  createdAt        DateTime @default(now())
  readAt           DateTime?
  pushDeliveredAt  DateTime?
  pushSuppressedAt DateTime?

  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailFallback  NotificationEmailFallback?

  @@index([userId, isRead, createdAt])
  @@index([userId, type, createdAt])
}

model WebPushSubscription {
  id          String   @id @default(cuid())
  userId      String
  endpoint    String   @unique
  p256dh      String
  auth        String
  deviceLabel String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model NotificationEmailFallback {
  id             String                  @id @default(cuid())
  userId         String
  notificationId String                  @unique
  templateKey    String
  status         NotificationEmailStatus @default(PENDING)
  payloadJson    Json
  availableAt    DateTime                @default(now())
  onlyIfUnread   Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  processedAt    DateTime?
  errorMessage   String?

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification  Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([userId, status, availableAt])
}

model Report {
  id               String @id @default(cuid())
  filedByUserId    String
  targetType       ReportTargetType
  targetUserId     String?
  targetPostId     String?
  targetCommentId  String?
  targetMessageId           String?
  targetMessageAttachmentId String?
  targetGroupId             String?
  reasonCode       String
  details          String?
  status           ReportStatus @default(OPEN)
  resolvedByUserId String?
  resolvedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  filedBy          User @relation("ReportFiledBy", fields: [filedByUserId], references: [id], onDelete: Cascade)
  resolvedBy       User? @relation("ReportResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  targetUser       User? @relation("ReportTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetPost       Post? @relation("ReportTargetPost", fields: [targetPostId], references: [id], onDelete: SetNull)
  targetComment    Comment? @relation("ReportTargetComment", fields: [targetCommentId], references: [id], onDelete: SetNull)
  targetMessage           Message?           @relation("ReportTargetMessage", fields: [targetMessageId], references: [id], onDelete: SetNull)
  targetMessageAttachment MessageAttachment? @relation("ReportTargetMessageAttachment", fields: [targetMessageAttachmentId], references: [id], onDelete: SetNull)
  targetGroup             Group?             @relation("ReportTargetGroup", fields: [targetGroupId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, createdAt])
}

model AuditLog {
  id           String @id @default(cuid())
  actorUserId  String?
  action       String
  targetType   String
  targetId     String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  actor        User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([targetType, targetId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
















